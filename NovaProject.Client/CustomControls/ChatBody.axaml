<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cc="using:NovaProject.CustomControls"
             xmlns:ccvm="using:NovaProject.CustomControls.ViewModels"
             xmlns:infrastructure="clr-namespace:NovaProject.Core.Infrastructure;assembly=NovaProject.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NovaProject.CustomControls.ChatBody"
             x:DataType="ccvm:ChatBodyViewModel">
    <ScrollViewer
        x:Name="ChatScroll"
        Classes="ChatBody">
        <Interaction.Behaviors>
            <!--<ia:VerticalScrollViewerAnimatedBehavior></ia:VerticalScrollViewerAnimatedBehavior>-->
        </Interaction.Behaviors>
        <StackPanel
            x:Name="MessageList">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.DataTemplates>
                    <DataTemplate DataType="{x:Type infrastructure:MessageOutgoing}">
                        <cc:ChatBubble MessageContent="{Binding Content}" SentAt="{Binding Time}"/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type infrastructure:MessageIncoming}">
                        <cc:ChatBubbleOther MessageContent="{Binding Content}" SentAt="{Binding Time}"/>
                    </DataTemplate>
                </ItemsControl.DataTemplates>
                <ItemsControl.ItemTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Panel Height="60"></Panel>
        </StackPanel>
    </ScrollViewer>
</UserControl>