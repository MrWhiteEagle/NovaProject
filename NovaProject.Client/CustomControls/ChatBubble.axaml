<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cc="clr-namespace:NovaProject.CustomControls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NovaProject.CustomControls.ChatBubble"
             x:DataType="cc:ChatBubble">
    <Grid
        ColumnDefinitions="50, 50, 50, 50, *, Auto"
        Classes="ChatBubbleSelfGrid"
        PointerEntered="InputElement_OnPointerEntered"
        PointerExited="InputElement_OnPointerExited">
        <Button
            x:Name="EditMessageButton"
            Classes="RegularIconButton"
            VerticalAlignment="Bottom"
            IsVisible="False">
            <PathIcon
                Data="{DynamicResource EditRegular}"></PathIcon>
        </Button>
        <Button
            Grid.Column="1"
            x:Name="RespondToMessageButton"
            Classes="RegularIconButton"
            VerticalAlignment="Bottom"
            IsVisible="False">
            <PathIcon
                Data="{DynamicResource ArrowReplyRegular}"></PathIcon>
        </Button>
        <Button
            Grid.Column="2"
            x:Name="DeleteMessageButton"
            Classes="RegularIconButton"
            VerticalAlignment="Bottom"
            IsVisible="False">
            <PathIcon
                Data="{DynamicResource DeleteRegular}"></PathIcon>
        </Button>
        <Button
            Grid.Column="3"
            x:Name="MoreMessageActionsButton"
            Classes="RegularIconButton"
            VerticalAlignment="Bottom"
            IsVisible="False">
            <PathIcon
                Data="{DynamicResource MoreRegular}"></PathIcon>
        </Button>
        <TextBlock
            Grid.Column="4"
            x:Name="TimeReceivedText"
            IsVisible="False"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,10,0"
            Foreground="{DynamicResource Gray100}"
            Text="{Binding $parent[cc:ChatBubble].SentAt, StringFormat='{}{0:HH:mm}'}"></TextBlock>
        <Border
            Grid.Column="5"
            x:Name="MessageBody"
            Classes="ChatBubbleSelf"
            HorizontalAlignment="Right">
            <TextBlock x:Name="MessageBlock" Text="{Binding $parent[cc:ChatBubble].MessageContent}" />
        </Border>
    </Grid>
</UserControl>