<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NovaProject.ViewModels"
        xmlns:cc="using:NovaProject.CustomControls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="NovaProject.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="NovaProject"
        Background="#111111">

    <SplitView
        DisplayMode="CompactInline"
        IsPaneOpen="{Binding IsPaneOpen}"
        CompactPaneLength="60">
        <SplitView.Pane>
            <StackPanel Spacing="5" Background="#111111">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="60">
                    <TabStrip
                        IsVisible="{Binding IsPaneOpen}"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding Tabs}"
                        SelectedIndex="{Binding CurrentTabIndex}">
                        <TabStripItem
                            Classes="PaneMenuItem">
                            <PathIcon Data="{DynamicResource ChatRegular}">
                            </PathIcon>
                        </TabStripItem>
                        <TabStripItem
                            Classes="PaneMenuItem">
                            <PathIcon Data="{DynamicResource GlobeRegular}"></PathIcon>
                        </TabStripItem>
                        
                    </TabStrip>
                    <Button
                        Grid.Column="1"
                        Command="{Binding OpenPaneCommand}"
                        Classes="PaneOpenButton"
                        Classes.expanded="{Binding IsPaneOpen}">
                        <PathIcon
                            Data="{DynamicResource ArrowRightRegular}">
                        </PathIcon>
                    </Button>
                </Grid>
                <Border>
                    <StackPanel
                        Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Right"
                        Margin="15"
                        IsVisible="{Binding IsPaneOpen}">
                        <Button
                            Classes="SimpleTextButton"
                            Foreground="WhiteSmoke"
                            FontWeight="Bold">
                            Add new +
                        </Button>
                    </StackPanel>
                </Border>
                <ContentControl Content="{Binding CurrentTab}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:UserListViewModel">
                            <cc:UserList>

                            </cc:UserList>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </StackPanel>
        </SplitView.Pane>
        <SplitView.Content>
            <Border
                CornerRadius="10,0,0,10"
                Background="#1e1e1e">
                <Grid RowDefinitions="72, *, Auto">
                    <cc:ChatTitlebar
                        x:Name="ChatTitle"
                        ZIndex="1">
                    </cc:ChatTitlebar>
                    <cc:ChatBody
                        x:Name="ChatBody"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        ZIndex="0"
                        DataContext="{Binding Body}">
                    </cc:ChatBody>
                    <cc:ChatInput
                        x:Name="ChatField"
                        Grid.Row="2"
                        ZIndex="1"
                        MessageSent="ChatField_OnMessageSent"
                        DataContext="{Binding Input}">
                    </cc:ChatInput>
                </Grid>
            </Border>
        </SplitView.Content>
    </SplitView>

</Window>